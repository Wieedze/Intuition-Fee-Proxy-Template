{
  "name": "intuition-fee-proxy-template",
  "version": "2.0.0-alpha",
  "private": true,
  "description": "Intuition Fee Proxy Template — monorepo (contracts + SDK + webapp + Factory)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "contracts:compile": "bun --filter @intuition-fee-proxy/contracts compile",
    "contracts:test": "bun --filter @intuition-fee-proxy/contracts test",
    "contracts:clean": "bun --filter @intuition-fee-proxy/contracts clean",
    "contracts:node": "bun --filter @intuition-fee-proxy/contracts node",
    "contracts:deploy:local": "bun --filter @intuition-fee-proxy/contracts deploy:local",
    "contracts:e2e:local": "bun --filter @intuition-fee-proxy/contracts e2e:local",
    "contracts:e2e:testnet": "bun --filter @intuition-fee-proxy/contracts e2e:testnet",
    "contracts:e2e:sponsored:local": "bun --filter @intuition-fee-proxy/contracts e2e:sponsored:local",
    "contracts:e2e:sponsored:testnet": "bun --filter @intuition-fee-proxy/contracts e2e:sponsored:testnet",
    "contracts:deploy:v3mock:local": "bun --filter @intuition-fee-proxy/contracts deploy:v3mock:local",
    "contracts:deploy:testnet": "bun --filter @intuition-fee-proxy/contracts deploy:testnet",
    "contracts:deploy:mainnet": "bun --filter @intuition-fee-proxy/contracts deploy:mainnet",
    "sdk:build": "bun --filter @intuition-fee-proxy/sdk build",
    "sdk:sync": "bun run scripts/sync-abis.ts",
    "webapp:dev": "bun --filter @intuition-fee-proxy/webapp dev",
    "webapp:build": "bun --filter @intuition-fee-proxy/webapp build",
    "webapp:preview": "bun --filter @intuition-fee-proxy/webapp preview"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
